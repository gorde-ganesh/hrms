generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////
// ENUMS
//////////////////////////////////////////

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  PROBATION
}

enum NotificationType {
  SYSTEM
  LEAVE
  PAYROLL
  PERFORMANCE
}

enum ComponentType {
  ALLOWANCE
  DEDUCTION
}

enum ChannelType {
  DM
  GROUP
  PUBLIC_CHANNEL
  PRIVATE_CHANNEL
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
  CASUAL
  MATERNITY
  PATERNITY
  UNPAID
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
  ON_HOLD
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum PerformanceStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  FINALIZED
}

enum PerformanceReviewPeriod {
  QUARTERLY
  HALF_YEARLY
  ANNUAL
}

enum TaxRegime {
  OLD
  NEW
}

// Identifies which statutory line item a component represents.
// Used by the payroll engine and challan generation to locate PF/ESI/TDS rows
// without relying on component names (which vary per company).
enum StatutoryComponentType {
  BASIC
  HRA
  SPECIAL_ALLOWANCE
  CONVEYANCE
  MEDICAL
  PF_EMPLOYEE
  PF_EMPLOYER
  ESI_EMPLOYEE
  ESI_EMPLOYER
  TDS
  PROFESSIONAL_TAX
  LOP
  BONUS
  GRATUITY
  ADVANCE
  CUSTOM
}

enum BankTransferStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

//////////////////////////////////////////
// COMPANY MODEL
//////////////////////////////////////////

model Company {
  id          String    @id @default(uuid())
  name        String
  gstin       String?
  pan         String?
  cin         String?
  address     String?
  city        String?
  state       String?   // Used as default professionalTaxState for employees
  pincode     String?
  phone       String?
  email       String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users                User[]
  departments          Department[]
  designations         Designation[]
  payrollComponentTypes PayrollComponentType[]
  holidayCalendars     HolidayCalendar[]
  bankTransferBatches  BankTransferBatch[]
}

//////////////////////////////////////////
// USER MODEL
//////////////////////////////////////////

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  phone           String
  address         String
  state           String
  city            String
  country         String
  zipCode         String
  roleId          String
  userRole        UserRole  @relation(fields: [roleId], references: [id])
  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  gender               String?   // MALE | FEMALE | OTHER
  resetToken           String?
  resetTokenExp        DateTime?
  refreshToken         String?
  refreshTokenExp      DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  tokenVersion         Int       @default(0)
  deletedAt            DateTime?

  employee             Employee?
  leavesApproved       Leave[]              @relation("LeaveApprovedBy")
  leavesManaged        Leave[]              @relation("LeaveManagerApproval")
  messagesSent         Message[]            @relation("SentMessages")
  conversations        ConversationMember[]
  callsMade            CallLog[]            @relation("Caller")
  callsReceived        CallLog[]            @relation("Receiver")
  conversationsCreated Conversation[]       @relation("CreatedBy")
  payrollsProcessed    Payroll[]            @relation("PayrollProcessedBy")
  auditLogs            AuditLog[]

  @@index([companyId])
}

//////////////////////////////////////////
// RBAC MODELS
//////////////////////////////////////////

model UserRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       UserRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

//////////////////////////////////////////
// DEPARTMENT MODEL
//////////////////////////////////////////

model Department {
  id          String    @id @default(uuid())
  name        String
  description String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////
// DESIGNATION MODEL
//////////////////////////////////////////

model Designation {
  id             String    @id @default(uuid())
  name           String
  description    String?
  classification String?
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

//////////////////////////////////////////
// EMPLOYEE MODEL
//////////////////////////////////////////

model Employee {
  id           String @id @default(uuid())
  employeeCode String @unique
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])

  joiningDate            DateTime?
  salary                 Decimal?  @db.Decimal(12, 2) // Annual CTC
  dob                    DateTime
  personalEmail          String
  bloodGroup             String
  emergencyContactPerson String
  emergencyContactNumber String
  status                 EmployeeStatus
  employmentType         EmploymentType @default(FULL_TIME)
  probationEndDate       DateTime?
  contractEndDate        DateTime?
  bankAccountNumber      String?
  bankName               String?
  ifscCode               String?
  panNumber              String?
  profileImageUrl        String?

  // Statutory fields
  uan                  String?   // Universal Account Number (PF)
  pfNumber             String?   // PF member ID at the establishment
  esiNumber            String?   // ESI insurance number (IP number)
  professionalTaxState String?   // State code for PT slab lookup (e.g. "MH", "KA")
  taxRegime            TaxRegime @default(NEW)
  pfOptOut             Boolean   @default(false) // Voluntary opt-out when basic > ₹15k

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  managerId    String?
  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  onboardingStatus OnboardingStatus @default(COMPLETED)

  leaves           Leave[]
  attendance       Attendance[]
  payrolls         Payroll[]
  performance      Performance[]
  notifications    Notification[]
  leaveBalance     LeaveBalance[]
  salaryStructures SalaryStructure[]
  onboardingTasks  OnboardingTask[]

  @@index([departmentId])
  @@index([managerId])
}

//////////////////////////////////////////
// SALARY STRUCTURE MODEL
//////////////////////////////////////////

// Effective-dated CTC breakdown. On each payroll run the engine picks the
// structure whose effectiveFrom <= payroll month and effectiveTo is null or >=
// payroll month. Needed for mid-year raises and Form 16 accuracy.
model SalaryStructure {
  id            String    @id @default(uuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date  // null = currently active

  ctcAnnual     Decimal   @db.Decimal(12, 2)
  basicPct      Decimal   @db.Decimal(5, 2) // basic as % of gross monthly (e.g. 40.00)
  hraPct        Decimal   @db.Decimal(5, 2) // HRA as % of basic (e.g. 50.00 for metro)

  createdAt     DateTime  @default(now())
  createdById   String?

  @@index([employeeId, effectiveFrom])
}

//////////////////////////////////////////
// LEAVE MODEL
//////////////////////////////////////////

model Leave {
  id         String      @id @default(uuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  reason     String
  leaveType  LeaveType   @default(ANNUAL)
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  approvedById      String?
  approvedBy        User?   @relation("LeaveApprovedBy", fields: [approvedById], references: [id])
  managerApprovalId String?
  managerApproval   User?   @relation("LeaveManagerApproval", fields: [managerApprovalId], references: [id])
  rejectionReason   String?
  approvalDate      DateTime?
  rejectionDate     DateTime?
  halfDay           Boolean @default(false)
  halfDayPeriod     String?

  @@index([employeeId])
  @@index([status])
  @@index([status, startDate])
}

//////////////////////////////////////////
// LEAVE BALANCE MODEL
//////////////////////////////////////////

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year        Int
  leaveType   LeaveType @default(ANNUAL)
  totalLeaves Int       @default(21)
  usedLeaves  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, year, leaveType])
}

//////////////////////////////////////////
// ATTENDANCE MODEL
//////////////////////////////////////////

model Attendance {
  id             String           @id @default(uuid())
  employeeId     String
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate DateTime         @db.Date
  checkIn        DateTime?
  checkOut       DateTime?
  totalHours     Float?
  status         AttendanceStatus @default(PRESENT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([employeeId, attendanceDate])
}

//////////////////////////////////////////
// PAYROLL MODEL (HEADER)
//////////////////////////////////////////

model Payroll {
  id              String        @id @default(uuid())
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  grossSalary     Decimal       @db.Decimal(12, 2) @default(0)
  basicSalary     Decimal       @db.Decimal(12, 2) @default(0)
  netSalary       Decimal       @db.Decimal(12, 2) @default(0)
  lopDays         Int           @default(0)   // Loss of Pay days this month
  workingDays     Int           @default(26)  // Payable working days this month
  status          PayrollStatus @default(DRAFT)
  paidDate        DateTime?
  processedById   String?
  processedBy     User?         @relation("PayrollProcessedBy", fields: [processedById], references: [id])
  idempotencyKey  String?       // Set on batch generation to prevent double-run
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  components PayrollComponent[]
  payslip    Payslip?
  bankTransferItem BankTransferItem?

  @@unique([employeeId, month, year])
  @@index([year, month])
  @@index([employeeId, createdAt])
  @@index([idempotencyKey])
}

//////////////////////////////////////////
// PAYSLIP MODEL
//////////////////////////////////////////

// Immutable record of the PDF generated at finalize time. Serves as the
// legal copy. If the payslip is regenerated, a new row replaces the old one
// (old row is soft-deleted via supersededAt).
model Payslip {
  id           String    @id @default(uuid())
  payrollId    String    @unique
  payroll      Payroll   @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  fileUrl      String    // Path on disk or S3 URL
  fileHash     String    // SHA-256 of PDF bytes — detect tampering
  generatedAt  DateTime  @default(now())
  supersededAt DateTime? // Non-null if a newer PDF was generated

  @@index([payrollId])
}

//////////////////////////////////////////
// PAYROLL COMPONENT TYPE
//////////////////////////////////////////

model PayrollComponentType {
  id             String                 @id @default(uuid())
  name           String
  description    String?
  type           ComponentType
  statutoryType  StatutoryComponentType? // null = custom non-statutory component
  isActive       Boolean                @default(true)
  percent        Decimal?               @db.Decimal(5, 2) // Default % for seeded components
  companyId      String?                // null = system-wide component available to all companies
  company        Company?               @relation(fields: [companyId], references: [id])
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  components PayrollComponent[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([statutoryType])
}

//////////////////////////////////////////
// PAYROLL COMPONENT
//////////////////////////////////////////

model PayrollComponent {
  id              String               @id @default(uuid())
  payrollId       String
  payroll         Payroll              @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  componentTypeId String
  componentType   PayrollComponentType @relation(fields: [componentTypeId], references: [id])
  amount          Decimal              @db.Decimal(12, 2) @default(0)

  @@unique([payrollId, componentTypeId])
}

//////////////////////////////////////////
// BANK TRANSFER MODELS
//////////////////////////////////////////

model BankTransferBatch {
  id          String             @id @default(uuid())
  month       Int
  year        Int
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id])
  status      BankTransferStatus @default(PENDING)
  fileUrl     String?            // NEFT/bank CSV download URL
  createdAt   DateTime           @default(now())
  createdById String?

  items BankTransferItem[]

  @@index([companyId, year, month])
}

model BankTransferItem {
  id              String            @id @default(uuid())
  batchId         String
  batch           BankTransferBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  payrollId       String            @unique
  payroll         Payroll           @relation(fields: [payrollId], references: [id])
  amount          Decimal           @db.Decimal(12, 2)
  accountNumber   String
  ifscCode        String
  beneficiaryName String
  status          BankTransferStatus @default(PENDING)

  @@index([batchId])
}

//////////////////////////////////////////
// PERFORMANCE MODEL
//////////////////////////////////////////

model Performance {
  id              String                  @id @default(uuid())
  employeeId      String
  employee        Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  goals           String
  rating          Int?
  comments        String?
  managerComments String?
  status          PerformanceStatus       @default(DRAFT)
  reviewPeriod    PerformanceReviewPeriod @default(ANNUAL)
  reviewDate      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([employeeId])
}

//////////////////////////////////////////
// NOTIFICATION MODEL
//////////////////////////////////////////

model Notification {
  id         String           @id @default(uuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       NotificationType
  message    String
  readStatus Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([employeeId])
  @@index([employeeId, readStatus])
}

//////////////////////////////////////////
// CHAT MODELS
//////////////////////////////////////////

model Conversation {
  id           String      @id @default(uuid())
  isGroup      Boolean     @default(false)
  name         String?
  description  String?
  channelType  ChannelType @default(DM)
  isPublic     Boolean     @default(false)
  isHuddle     Boolean     @default(false)
  huddleActive Boolean     @default(false)
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdBy User?                @relation("CreatedBy", fields: [createdById], references: [id])
  members   ConversationMember[]
  messages  Message[]
}

model ConversationMember {
  id             String    @id @default(uuid())
  userId         String
  conversationId String
  role           String?   @default("member")
  lastReadAt     DateTime? @default(now())

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  messageText    String?
  messageType    String   @default("text")
  fileUrl        String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
}

model CallLog {
  id         String    @id @default(uuid())
  callerId   String
  receiverId String
  callType   String    @default("video")
  status     String    @default("missed")
  startTime  DateTime  @default(now())
  endTime    DateTime?

  caller   User @relation("Caller", fields: [callerId], references: [id])
  receiver User @relation("Receiver", fields: [receiverId], references: [id])
}

//////////////////////////////////////////
// HOLIDAY CALENDAR MODEL
//////////////////////////////////////////

model HolidayCalendar {
  id        String   @id @default(uuid())
  name      String
  date      DateTime @db.Date
  type      String   @default("PUBLIC")
  year      Int
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  @@index([year])
  @@index([date])
  @@index([companyId, year])
}

//////////////////////////////////////////
// AUDIT LOG MODEL
//////////////////////////////////////////

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, PASSWORD_RESET
  entity      String   // Employee, Leave, Payroll, User, etc.
  entityId    String?
  performedBy String
  user        User     @relation(fields: [performedBy], references: [id])
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([performedBy])
  @@index([entity, entityId])
  @@index([createdAt])
}

//////////////////////////////////////////
// LEAVE POLICY MODEL
//////////////////////////////////////////

model LeavePolicy {
  id                   String    @id @default(uuid())
  leaveType            LeaveType @unique
  maxDays              Int
  carryForwardDays     Int       @default(0)
  requiresCertificate  Boolean   @default(false)
  minNoticeDays        Int       @default(0)
  genderRestriction    String?   // MALE | FEMALE | null means no restriction
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

//////////////////////////////////////////
// ONBOARDING MODELS
//////////////////////////////////////////

enum OnboardingStatus {
  INVITED
  PROFILE_PENDING
  DOCUMENTS_PENDING
  IT_SETUP_PENDING
  COMPLETED
}

model OnboardingTask {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  category    String    // DOCUMENTS | IT_SETUP | POLICIES | PAYROLL
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  @@index([employeeId])
  @@index([employeeId, completed])
}
