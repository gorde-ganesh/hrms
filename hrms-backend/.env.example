# =============================================================
# HRMS Backend — Environment Variables
# Copy this file to .env and fill in the values.
# All variables marked REQUIRED must be set; the server will
# refuse to start if they are missing.
# =============================================================

# ----- Database (REQUIRED) -----------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/hrms_db"

# ----- Auth (REQUIRED) ---------------------------------------
# Minimum 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_KEY="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- Server ------------------------------------------------
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# ----- CORS --------------------------------------------------
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:4200

# ----- Email (SMTP) ------------------------------------------
# Required for password-reset and onboarding emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com
APP_URL=https://yourdomain.com

# ----- Redis (optional, enables horizontal Socket.IO scaling) -
# REDIS_URL=redis://localhost:6379
